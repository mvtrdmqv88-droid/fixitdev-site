---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "FixItDev — Simple tools that solve real problems." } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/fixitdev-site/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} | FixItDev</title>
    <style is:global>
      @import "../styles/global.css";
    </style>
  </head>
  <body>
    <nav class="nav">
      <div class="container nav-inner">
        <a href="/fixitdev-site/" class="logo">⚡ FixItDev</a>
        <div class="nav-links">
          <a href="/fixitdev-site/#tools">Tools</a>
          <a href="/fixitdev-site/blog">Blog</a>
          <a href="https://github.com/mvtrdmqv88-droid" target="_blank">GitHub</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container footer-inner">
        <p>Made with ❤️ by FixItDev</p>
        <p class="footer-muted">An indie dev solving one problem at a time.</p>
      </div>
    </footer>

    <style>
      .nav {
        border-bottom: 1px solid var(--color-border);
        padding: 1rem 0;
        position: sticky;
        top: 0;
        background: var(--color-bg);
        z-index: 100;
      }
      .nav-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .logo {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--color-text);
      }
      .logo:hover { text-decoration: none; color: var(--color-accent); }
      .nav-links { display: flex; gap: 1.5rem; }
      .nav-links a { color: var(--color-text-muted); font-size: 0.95rem; }
      .nav-links a:hover { color: var(--color-text); text-decoration: none; }
      .footer {
        border-top: 1px solid var(--color-border);
        padding: 2rem 0;
        margin-top: 4rem;
        text-align: center;
      }
      .footer-muted { color: var(--color-text-muted); font-size: 0.85rem; margin-top: 0.25rem; }
    </style>
  </body>
</html>
