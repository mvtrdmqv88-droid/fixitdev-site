---
import Base from "../../layouts/Base.astro";
---

<Base title="PortalKit" description="Stop chasing clients for files. Build a custom onboarding portal in minutes. Free for freelancers.">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <span class="badge">Built for freelancers</span>
      <h1 class="hero-title">Stop sending "hey, can you send me that file?" emails.</h1>
      <p class="hero-subtitle">
        PortalKit lets you build a custom client onboarding portal in minutes.
        Share one link. Get everything you need. Move on with your life.
      </p>
      <div class="hero-actions">
        <a href="https://github.com/mvtrdmqv88-droid/portalkit" class="btn btn-primary">Try it free</a>
        <a href="#how-it-works" class="btn btn-secondary">See how it works</a>
      </div>
    </div>
  </section>

  <!-- Pain Points -->
  <section class="pain-section">
    <div class="container">
      <h2 class="section-title">Sound familiar?</h2>
      <div class="pain-grid">
        <div class="pain-card">
          <span class="pain-icon">&#x1F4E7;</span>
          <h3>The endless email chain</h3>
          <p>"Can you send your logo?" "What's the brand color?" "Do you have a style guide?" Five emails later, you still don't have everything.</p>
        </div>
        <div class="pain-card">
          <span class="pain-icon">&#x1F4C1;</span>
          <h3>Missing files, missing context</h3>
          <p>Half the assets arrive in random email threads. The other half? "Oh sorry, I forgot to attach that." You start a project with incomplete info every single time.</p>
        </div>
        <div class="pain-card">
          <span class="pain-icon">&#x1F612;</span>
          <h3>Unprofessional first impression</h3>
          <p>You're a pro, but your onboarding process is a messy Google Form or a bulleted list in an email. Your clients deserve better. So do you.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="how-it-works" class="how-section">
    <div class="container">
      <h2 class="section-title">How it works</h2>
      <p class="section-desc">Three steps. No learning curve. Seriously.</p>
      <div class="steps-grid">
        <div class="step-card">
          <span class="step-num">1</span>
          <h3>Build your portal</h3>
          <p>Drag and drop the fields you need: text, file uploads, dropdowns, dates. Make it yours in minutes.</p>
        </div>
        <div class="step-card">
          <span class="step-num">2</span>
          <h3>Share the link</h3>
          <p>Send your client a single, clean URL. No account required on their end. They just click and fill in.</p>
        </div>
        <div class="step-card">
          <span class="step-num">3</span>
          <h3>Get everything at once</h3>
          <p>All files, answers, and assets land in one place. No more digging through email. Start the project.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features-section">
    <div class="container">
      <h2 class="section-title">What you get</h2>
      <div class="features-grid">
        <div class="feature">
          <h3>Drag & drop builder</h3>
          <p>Build your onboarding form visually. Reorder fields, add sections, customize labels. No code.</p>
        </div>
        <div class="feature">
          <h3>Multiple field types</h3>
          <p>Text, email, file upload, dropdown, checkbox, date picker, long text. Everything you actually need.</p>
        </div>
        <div class="feature">
          <h3>Shareable links</h3>
          <p>Each portal gets a unique URL. Send it to your client. They fill it out. Done.</p>
        </div>
        <div class="feature">
          <h3>No client sign-up</h3>
          <p>Your clients don't need to create an account. Less friction means they actually complete the form.</p>
        </div>
        <div class="feature">
          <h3>Mobile-friendly</h3>
          <p>Clients can fill in your portal from their phone. Because that's where they'll be when they finally do it.</p>
        </div>
        <div class="feature">
          <h3>Clean, professional look</h3>
          <p>Your portal looks like you paid a designer. But you didn't. You're welcome.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="pricing-section">
    <div class="container">
      <h2 class="section-title">Pricing</h2>
      <p class="section-desc">Start free. Upgrade when you're ready.</p>
      <div class="pricing-grid">
        <div class="price-card">
          <h3>Free</h3>
          <div class="price">$0</div>
          <p class="price-period">forever</p>
          <ul class="price-features">
            <li>1 client portal</li>
            <li>All field types</li>
            <li>Shareable link</li>
            <li>Mobile-friendly</li>
          </ul>
          <a href="https://github.com/mvtrdmqv88-droid/portalkit" class="btn btn-secondary">Get started</a>
        </div>
        <div class="price-card price-card-pro">
          <span class="pro-badge">Most popular</span>
          <h3>Pro</h3>
          <div class="price">$19<span class="price-unit">/mo</span></div>
          <p class="price-period">or $49 one-time payment</p>
          <ul class="price-features">
            <li>Unlimited portals</li>
            <li>All field types</li>
            <li>Shareable links</li>
            <li>Mobile-friendly</li>
            <li>Priority support</li>
          </ul>
          <a href="https://github.com/mvtrdmqv88-droid/portalkit" class="btn btn-primary">Go Pro</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <h2 class="section-title">FAQ</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>Do my clients need to create an account?</summary>
          <p>Nope. They just click the link and fill in the form. Zero friction.</p>
        </details>
        <details class="faq-item">
          <summary>What file types can clients upload?</summary>
          <p>Pretty much anything: images, PDFs, ZIPs, PSD files, fonts. If it's a file, they can upload it.</p>
        </details>
        <details class="faq-item">
          <summary>Can I customize the portal with my branding?</summary>
          <p>The portal uses a clean, minimal design that works for any brand. Custom branding (logos, colors) is on the roadmap.</p>
        </details>
        <details class="faq-item">
          <summary>What happens after a client submits?</summary>
          <p>You get notified and can view all their responses and files in one organized dashboard. No more digging through email threads.</p>
        </details>
        <details class="faq-item">
          <summary>Why not just use Google Forms?</summary>
          <p>You can! But Google Forms wasn't built for this. No proper file handling, no professional look, and your clients will judge you. Just a little.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bottom-cta">
    <div class="container">
      <h2>Ready to stop chasing clients?</h2>
      <p>Build your first portal in under 5 minutes. Free, no credit card.</p>
      <a href="https://github.com/mvtrdmqv88-droid/portalkit" class="btn btn-primary">Create your portal</a>
    </div>
  </section>
</Base>

<style>
  /* Hero */
  .hero {
    padding: 5rem 0 4rem;
    text-align: center;
  }
  .badge {
    display: inline-block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }
  .hero-title {
    font-size: 2.5rem;
    font-weight: 800;
    max-width: 700px;
    margin: 0 auto 1rem;
    line-height: 1.2;
  }
  .hero-subtitle {
    color: var(--color-text-muted);
    font-size: 1.15rem;
    max-width: 550px;
    margin: 0 auto 2rem;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Buttons */
  .btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s;
    text-decoration: none;
  }
  .btn:hover { text-decoration: none; }
  .btn-primary {
    background: var(--color-accent);
    color: #fff;
  }
  .btn-primary:hover { background: var(--color-accent-hover); }
  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }
  .btn-secondary:hover { border-color: var(--color-accent); }

  /* Section shared */
  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .section-desc {
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
  }

  /* Pain Points */
  .pain-section {
    padding: 4rem 0;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .pain-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .pain-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .pain-icon {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 0.75rem;
  }
  .pain-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.5rem;
  }
  .pain-card p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  /* How It Works */
  .how-section { padding: 4rem 0; }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .step-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: var(--color-accent);
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
    border-radius: 50%;
    margin-bottom: 0.75rem;
  }
  .step-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.5rem;
  }
  .step-card p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  /* Features */
  .features-section {
    padding: 4rem 0;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .feature {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .feature h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }
  .feature p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  /* Pricing */
  .pricing-section { padding: 4rem 0; }
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    max-width: 700px;
    margin: 0 auto;
    margin-top: 2rem;
  }
  .price-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    position: relative;
  }
  .price-card-pro {
    border-color: var(--color-accent);
  }
  .pro-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-accent);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.75rem;
    border-radius: 999px;
  }
  .price-card h3 {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
  }
  .price {
    font-size: 2.5rem;
    font-weight: 800;
  }
  .price-unit {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-muted);
  }
  .price-period {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
  }
  .price-features {
    list-style: none;
    text-align: left;
    margin-bottom: 1.5rem;
  }
  .price-features li {
    padding: 0.4rem 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
  }
  .price-features li:last-child { border-bottom: none; }
  .price-features li::before {
    content: "\2713  ";
    color: var(--color-success);
    margin-right: 0.25rem;
  }

  /* FAQ */
  .faq-section { padding: 4rem 0; }
  .faq-list {
    max-width: 700px;
    margin-top: 2rem;
  }
  .faq-item {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    margin-bottom: 0.75rem;
    overflow: hidden;
  }
  .faq-item summary {
    padding: 1rem 1.25rem;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.95rem;
    background: var(--color-surface);
  }
  .faq-item summary:hover { color: var(--color-accent); }
  .faq-item p {
    padding: 0 1.25rem 1rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  /* Bottom CTA */
  .bottom-cta {
    padding: 5rem 0;
    text-align: center;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
  }
  .bottom-cta h2 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }
  .bottom-cta p {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  @media (max-width: 640px) {
    .hero-title { font-size: 1.75rem; }
    .hero-subtitle { font-size: 1rem; }
    .section-title { font-size: 1.35rem; }
    .price { font-size: 2rem; }
  }
</style>
