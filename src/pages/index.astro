---
import Base from "../layouts/Base.astro";
import ToolCard from "../components/ToolCard.astro";

// Tools will be added here by 黑嘴 as they are completed
const tools: { name: string; tagline: string; href: string; tags: string[] }[] = [
  { name: "ContractScan", tagline: "AI-powered contract review for freelancers. Upload a PDF, get instant risk analysis and suggested edits.", href: "/fixitdev-site/tools/contractscan", tags: ["AI", "Freelancer", "Contracts"] },
  { name: "SwiftAPI", tagline: "Zero-login API testing in your browser. No install, no cloud sync — just send requests and see responses.", href: "/fixitdev-site/tools/swiftapi", tags: ["API", "HTTP Client", "Browser"] },
  { name: "PortalKit", tagline: "Client onboarding portal builder. Share one link, collect everything you need. No more chasing clients for files.", href: "/fixitdev-site/tools/portalkit", tags: ["Freelancer", "Onboarding", "React"] },
  { name: "Sandbox CLI", tagline: "Instant ephemeral dev environments via SSH. One command in, auto-cleanup on disconnect.", href: "/fixitdev-site/tools/sandbox-cli", tags: ["CLI", "Docker", "DevOps"] },
  { name: "MRRScope", tagline: "SaaS metrics dashboard for indie founders. Connect Stripe, see your MRR, Churn, LTV and more.", href: "/fixitdev-site/tools/mrrscope", tags: ["SaaS", "Stripe", "Analytics"] },
];
---

<Base title="Home" description="FixItDev — Simple developer tools that solve real problems. Built by an indie dev who gets frustrated by the same things you do.">
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">Hi, I'm <span class="accent">FixItDev</span>.</h1>
      <p class="hero-subtitle">
        I build small tools that solve real problems.<br />
        No bloat. No sign-up walls. Just things that work.
      </p>
      <a href="#tools" class="hero-cta">See what I've built ↓</a>
    </div>
  </section>

  <section id="tools" class="tools-section">
    <div class="container">
      <h2 class="section-title">Tools</h2>
      {tools.length === 0 ? (
        <p class="empty-state">First tools coming soon. Stay tuned.</p>
      ) : (
        <div class="tools-grid">
          {tools.map((tool) => (
            <ToolCard name={tool.name} tagline={tool.tagline} href={tool.href} tags={tool.tags} />
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="about-section">
    <div class="container">
      <h2 class="section-title">About</h2>
      <div class="about-content">
        <p>
          I'm an indie developer who keeps running into small annoyances that nobody has properly solved.
          So I started building tools myself — and sharing them with everyone who has the same frustrations.
        </p>
        <p>
          Every tool here is something I actually use. If it helps you too, that's awesome.
          If you find a bug or want a feature, just open an issue on GitHub — I read all of them.
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: 6rem 0 4rem;
    text-align: center;
  }
  .hero-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .accent { color: var(--color-accent); }
  .hero-subtitle {
    color: var(--color-text-muted);
    font-size: 1.2rem;
    max-width: 500px;
    margin: 0 auto 2rem;
  }
  .hero-cta {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    transition: background 0.2s;
  }
  .hero-cta:hover { background: var(--color-accent-hover); text-decoration: none; }

  .tools-section, .about-section { padding: 4rem 0; }
  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 2rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }
  .empty-state { color: var(--color-text-muted); font-style: italic; }
  .about-content {
    max-width: 650px;
    color: var(--color-text-muted);
  }
  .about-content p { margin-bottom: 1rem; }

  @media (max-width: 640px) {
    .hero-title { font-size: 1.75rem; }
    .hero-subtitle { font-size: 1rem; }
  }
</style>
