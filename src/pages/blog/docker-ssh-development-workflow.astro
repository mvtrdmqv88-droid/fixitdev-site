  .post-cta {
    margin-top: 3rem;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-accent);
    border-radius: 10px;
    text-align: center;
  }
  .cta-link {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 1.05rem;
  }

  @media (max-width: 640px) {
    .post-title { font-size: 1.5rem; }
  }
</style>
