---
import Base from "../layouts/Base.astro";

// Blog posts will be added here by 黑嘴 as tools are completed
const posts: { title: string; date: string; href: string; excerpt: string }[] = [
  { title: "7 Contract Red Flags Every Freelancer Should Watch For", date: "2026-04-07", href: "/blog/freelancer-contract-red-flags", excerpt: "Most freelancers sign contracts without fully reading them. Here are the clauses that can actually hurt you." },
  { title: "Best AI Contract Review Tools for Freelancers in 2026", date: "2026-04-07", href: "/blog/ai-contract-review-tools-2026", excerpt: "I tested the main AI contract review tools so you don't have to. Here's what actually works." },
  { title: "How to Review a Freelance Contract in 5 Minutes (Without a Lawyer)", date: "2026-04-07", href: "/blog/how-to-review-freelance-contract", excerpt: "A practical, step-by-step process for reviewing any freelance contract quickly and confidently." },
  { title: "Why Developers Are Leaving Postman (And What They're Using Instead)", date: "2026-04-07", href: "/blog/why-developers-leaving-postman", excerpt: "Postman's mandatory login, cloud sync, and growing complexity are pushing developers toward simpler tools. Here's what's happening." },
  { title: "5 Lightweight Postman Alternatives for Developers Who Just Want to Test APIs", date: "2026-04-07", href: "/blog/postman-alternatives-2026", excerpt: "Tired of Postman's bloat? Here are 5 lightweight API testing tools that get out of your way." },
  { title: "How to Test APIs Directly in Your Browser — No Install Required", date: "2026-04-07", href: "/blog/browser-api-testing-no-install", excerpt: "Step-by-step tutorial: send HTTP requests, inspect responses, and organize collections from a browser tab." },
  { title: "The Complete Guide to Client Onboarding for Freelancers", date: "2026-04-07", href: "/blog/client-onboarding-freelancer-guide", excerpt: "If you're a freelancer who has ever started a project with incomplete info, this guide is for you." },
  { title: "Stop Chasing Clients for Files: How to Automate Your Onboarding", date: "2026-04-07", href: "/blog/stop-chasing-clients-for-files", excerpt: "A step-by-step tutorial on setting up a client intake portal that collects everything you need." },
  { title: "Best Client Portal Tools for Freelancers in 2026", date: "2026-04-07", href: "/blog/client-portal-tools-freelancers-2026", excerpt: "I tested the most popular client onboarding tools so you don't have to. Here's what works." },
  { title: "Ephemeral Dev Environments: Why You Should Use Disposable Containers", date: "2026-04-07", href: "/blog/ephemeral-dev-environments-guide", excerpt: "Your laptop is a graveyard of forgotten tools. Ephemeral containers fix that." },
  { title: "How to Use Docker Containers as Instant SSH Development Environments", date: "2026-04-07", href: "/blog/docker-ssh-development-workflow", excerpt: "Step-by-step: one command to a fresh Linux environment, auto-cleanup on exit." },
  { title: "How to Keep Your Dev Machine Clean (Without Sacrificing Productivity)", date: "2026-04-07", href: "/blog/keep-dev-machine-clean", excerpt: "Practical tips to stop accumulating dev tools you'll never use again." },
  { title: "The Only 6 SaaS Metrics Indie Founders Actually Need to Track", date: "2026-04-07", href: "/blog/saas-metrics-indie-founders", excerpt: "Skip the vanity metrics. Here are the 6 SaaS numbers that actually tell you if your business is healthy." },
  { title: "Affordable Baremetrics Alternatives for Early-Stage SaaS (2026)", date: "2026-04-07", href: "/blog/baremetrics-alternatives-2026", excerpt: "When you're making $500/mo, spending $108/year on analytics feels like a bad joke. Let's look at what else is out there." },
  { title: "How to Calculate MRR, Churn Rate, and LTV for Your SaaS", date: "2026-04-07", href: "/blog/calculate-mrr-churn-ltv", excerpt: "The formulas aren't complicated. The hard part is knowing where to get the numbers and what to do with them." },
];
---

<Base title="Blog" description="FixItDev Blog — Tutorials, comparisons, and tips from an indie developer.">
  <section class="blog-section">
    <div class="container">
      <h1 class="page-title">Blog</h1>
      <p class="page-desc">Tutorials, comparisons, and the occasional rant about tools that don't work.</p>

      {posts.length === 0 ? (
        <p class="empty-state">First posts coming soon.</p>
      ) : (
        <div class="posts-list">
          {posts.map((post) => (
            <a href={post.href} class="post-card">
              <time class="post-date">{post.date}</time>
              <h2 class="post-title">{post.title}</h2>
              <p class="post-excerpt">{post.excerpt}</p>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Base>

<style>
  .blog-section { padding: 4rem 0; }
  .page-title { font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem; }
  .page-desc { color: var(--color-text-muted); margin-bottom: 3rem; }
  .posts-list { display: flex; flex-direction: column; gap: 1rem; }
  .post-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.2s;
    text-decoration: none;
  }
  .post-card:hover { border-color: var(--color-accent); text-decoration: none; }
  .post-date { color: var(--color-text-muted); font-size: 0.8rem; }
  .post-title { color: var(--color-text); font-size: 1.15rem; margin: 0.25rem 0 0.5rem; }
  .post-excerpt { color: var(--color-text-muted); font-size: 0.9rem; }
  .empty-state { color: var(--color-text-muted); font-style: italic; }
</style>
